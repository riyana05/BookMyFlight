# Copy this file to ".env" for local development and fill in your real values.
# .env should NEVER be committed to git (it's already in .gitignore).
#
# On Vercel, do NOT upload a .env file — instead add these same keys under
# Project Settings → Environment Variables in the Vercel dashboard.

# ── Server ─────────────────────────────────────────────────────
PORT=3000
# Used to sign JWT auth cookies (admin login + customer OTP login).
# Generate a strong random value, e.g.: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-long-random-string

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get this from Atlas: Database > Connect > Drivers > Node.js
# Replace <username>, <password>, and <cluster-url> with your own.
# Used for: deals, bookings, and customer accounts (email OTP login).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/bookmyflight?retryWrites=true&w=majority

# ── Email (SMTP) — used to send the OTP login code ─────────────
# Works with Gmail (use an App Password, not your normal password),
# Outlook, SendGrid SMTP relay, Mailtrap, etc.
# If left unset, OTP codes are printed to the server console instead
# (useful for local testing, but won't work on Vercel logs in real use).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Book My Flight

# ── OTP settings ────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
